@startuml ghwf-state-machine
title GHWF ワークフロー ステートマシン

skinparam state {
  BackgroundColor<<loop>> LightGreen
  BackgroundColor<<terminal>> LightGray
  BackgroundColor<<daemon>> LightYellow
}

[*] --> Idle

state "待機中" as Idle <<daemon>> {
  Idle : ghwf ラベル付きIssue
  Idle : デーモン監視中 (60秒間隔)
}

' ===== 実行中 (ghwf1-7) =====

state "実行中" as Exec {

  state "ghwf1-kickoff" as S1
  note right of S1
    ブランチ作成 + Draft PR作成
    git push -u origin <branch>
  end note
  state "ghwf2-spec" as S2
  state "ghwf3-plan" as S3
  state "ghwf4-review" as S4
  state "ghwf5-implement" as S5 {
    state "ステップ[i] 実装 & コミット" as S5i
    state "全完了?" as S5check <<choice>>
    state "プッシュ" as S5push

    [*] --> S5i
    S5i --> S5check
    S5check --> S5i : i < total
    S5check --> S5push : i == total
    S5push --> [*]

    note right of S5i
      1回の実行で全ステップを処理:
      ステップごとにコミット、
      最後に1回プッシュ
    end note
  }
  state "ghwf6-verify" as S6
  state "ghwf7-pr" as S7

  [*] --> S1
  S1 --> S2 : commit & push
  S2 --> S3 : commit & push
  S3 --> S4 : commit & push
  S4 --> S5 : commit & push
  S5 --> S6 : commit & push
  S6 --> S7 : commit & push
  S7 --> [*] : GitHub操作のみ\n(git操作なし)
}

' ===== 通常フロー =====

Idle --> Exec : ghwf:exec

state "完了" as Done <<terminal>>
Exec --> Done
Done --> [*]

' ===== 承認待ち =====

state "承認待ち" as Wait <<daemon>> {
  Wait : ghwf:waiting
  Wait : ユーザー承認待ち
}

Exec --> Wait : 自動実行上限到達
Wait --> Exec : ghwf:exec\n(次のステップを再開)

' ===== やり直し / リビジョン =====

Wait -[dashed]-> Exec : ghwf:redo\nghwf:redo-N
Wait -[dashed]-> Exec : ghwf:revision\n(ステップ1から再開)

note right of Exec
  **ghwf:redo** — 現在のステップを再実行
  **ghwf:redo-N** — ステップNまでロールバック
  **ghwf:revision** — 全体再実行 (リビジョン番号加算)
end note

' ===== ブロック中 =====

state "ブロック中" as Block <<daemon>> {
  state "依存待ち" as WDep
  state "サブIssue待ち" as WSub

  WDep : ghwf:waiting-deps
  WSub : ghwf:waiting-subs
}

Idle --> Block : 未解決の依存関係\nまたはサブIssue
Block --> Idle : 解決済み

note bottom of Block
  ブロック判定はGitHub Issue APIで検出:
  - 依存待ち: Issue Dependencies (blocked_by)
  - サブIssue待ち: Sub-issues API
  ラベルはトリガーではなく状態の可視化用。
  デーモンが自動で付与・除去する。
end note

' ===== 停止 =====

state "停止" as Stop <<terminal>>

Wait --> Stop : ghwf:stop
Idle --> Stop : ghwf:stop

' ===== 凡例 =====

legend right
  |= ラベル |= 自動実行範囲 |
  | ghwf:auto-to-2 | ステップ2 (仕様書) まで |
  | ghwf:auto-to-3 | ステップ3 (計画) まで |
  | ghwf:auto-to-4 | ステップ4 (レビュー) まで |
  | ghwf:auto-to-5 | ステップ5 (実装) まで |
  | ghwf:auto-to-6 | ステップ6 (検証) まで |
  | ghwf:auto-all | 全ステップ |
endlegend

@enduml
